{
  "hosting": {
    "public": "website/dist",
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/find-a-coach.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/coaches.html",
        "destination": "/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/coaches/**",
        "destination": "/coach-profile.html"
      }
    ]
  }
}
